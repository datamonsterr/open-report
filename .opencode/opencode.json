{
  "name": "open-report",
  "description": "Generate professional HTML reports with diagrams, charts, and codebase analysis",
  "version": "1.0.0",
  "commands": ["generate-report"],
  "subagents": ["diagram-renderer", "tester", "report-renderer", "srs-writer"],
  "dependencies": {
    "python": ">=3.10",
    "system": ["mermaid-cli", "plantuml", "graphviz"]
  },
  "output": {
    "dir": "output",
    "formats": ["html"]
  }
}
